# Database (PostgreSQL)
# Option A: Use 'auction' user (run scripts/create-db.sql first)
DATABASE_URL="postgresql://auction:auction123@localhost:5432/auction_db"

# Option B: Use your postgres user (create auction_db first: createdb -U postgres auction_db)
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/auction_db"

# Server
PORT=3000

# JWT
JWT_SECRET="your-secret-key"
# Access token lifetime (default 3h). Examples: 15m, 3h, 10800 (seconds)
# JWT_ACCESS_EXPIRY="3h"
# JWT_REFRESH_EXPIRY="7d"

# Optional: CORS / client origin (when frontend is on different host)
# CLIENT_ORIGIN="http://localhost:4200"
